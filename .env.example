# .env — AI投研系统多模型配置模板
# 作者：wangzongbao
# 说明：本地运行时请保存为.env，并填写真实API Key/Token

# ====================
# 大模型配置（国内主流模型）
# ====================
# 1. DeepSeek 深度求索
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 2. 阿里云 通义千问 (Qwen)
QWEN_API_KEY=your_qwen_api_key_here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 3. 百度 文心一言 (ERNIE)
ERNIE_API_KEY=your_ernie_api_key_here
ERNIE_BASE_URL=https://aip.baidubce.com/rpc/2.0/ai_custom/v1/wenxinworkshop/chat/completions

# 4. 字节跳动 豆包 (Doubao)
DOUBAO_API_KEY=your_doubao_api_key_here
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 5. 讯飞星火 (Spark)
SPARK_API_KEY=your_spark_api_key_here
SPARK_BASE_URL=https://spark-api.xf-yun.com/v1.1/chat

# 6. 腾讯 混元 (Hunyuan)
HUNYUAN_API_KEY=your_hunyuan_api_key_here
HUNYUAN_BASE_URL=https://hunyuan.tencentcloudapi.com

# ====================
# 数据接口配置
# ====================
AKSHARE_TIMEOUT=30  # akshare接口超时时间（秒）
TUSHARE_TOKEN=your_tushare_token_here  # 可选，无则留空
